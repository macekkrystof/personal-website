@using PersonalWebsite.Shared.Models
<section class="resume-section" id="hobbies">
    <div class="resume-section-content">
        <div class="row">
            <div class="col-md-6">
                <h2 class="mb-5">@HobbiesTitle</h2>
                <p>@HobbiesText</p>
            </div>
            <div class="col-md-6">
                <h2 class="mb-5">@VolunteeringActivitiesTitle</h2>
                @foreach (var e in VolunteeringActivitiesList ?? new List<Employment>())
                {
                    <div class="d-flex flex-column flex-md-row justify-content-between mb-5">
                        <div class="flex-grow-1">
                            <h3 class="mb-0">@e.PositionTitle</h3>
                            <div class="subheading mb-3">@(!string.IsNullOrEmpty(e.CompanyName) ? $"{e.CompanyName} · " : string.Empty) @e.City @(!string.IsNullOrEmpty(e.Country) ? $", {e.Country}" : string.Empty) </div>
                            <p>@e.Description</p>
                        </div>
                        <div class="flex-shrink-0"><span class="text-primary">@e.MonthAndYearFrom.ToString() @(e.MonthAndYearTo != null ? $"- {e.MonthAndYearTo}" : string.Empty)</span></div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
@code {
    [Parameter]
    public string HobbiesTitle { get; set; }

    [Parameter]
    public string VolunteeringActivitiesTitle { get; set; }

    [Parameter]
    public string HobbiesText { get; set; }

    [Parameter]
    public List<Employment> VolunteeringActivitiesList { get; set; }
}
