@page "/"
@using PersonalWebsite.Shared.Models
@using System.Net.Http
@inject HttpClient httpClient;
@inject IJSRuntime JSRuntime;



@code {
    
    public Biography Biography { get; set; }
    
    public async Task<string> GetBrowserLanguage()  
    {  
        string code = await JSRuntime.InvokeAsync<string>("navigatorLanguage");
        return code.Substring(0, 2);
    }

    protected override async Task OnInitializedAsync()
    {
        Biography = await httpClient.GetFromJsonAsync<Biography>($"api/GetBiography?languageCode={await GetBrowserLanguage()}");
    }

}